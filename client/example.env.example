# Required
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-char-secret-here  # must match server's NEXTAUTH_SECRET

# Internal key — must match server's INTERNAL_API_KEY
INTERNAL_API_KEY=change-me-to-a-random-64-char-string

# Backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SOCKET_URL=http://localhost:8080

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
