# Render builds from the repo root — keep build context small.
# client/ goes to Vercel, not into the backend image.
client/
**/node_modules/
**/.next/
**/.git/
**/__pycache__/
**/*.pyc
**/venv/
**/.venv/
server/sample-data/
**/*.log
.DS_Store
.env
.env.*
!server/.env.example
!client/example.env.example
docker-compose.yml
